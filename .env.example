# =====================================================
#  VibeGuard Sentinel v24.0 — Переменные окружения
#  Скопируй в .env и заполни значениями
# =====================================================

# ── ОБЯЗАТЕЛЬНЫЕ ────────────────────────────────────
TELEGRAM_TOKEN=your_telegram_bot_token
OPBNB_HTTP_URL=https://opbnb-mainnet.nodereal.io/v1/YOUR_KEY
DATABASE_URL=postgresql://user:password@host:5432/dbname
PRIMARY_OWNER_ID=449160262
# Обязательно https:// (иначе в Telegram: ERR_UNKNOWN_URL_SCHEME). Репозиторий: github.com/Tarran6/VibeGuard-Web
WEBAPP_URL=https://tarran6.github.io/VibeGuard-Web/

# ── AI-КЛЮЧИ (хотя бы один) ─────────────────────────
XAI_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=

# ── GOPLUS (опционально) ────────
GOPLUS_APP_KEY=
GOPLUS_APP_SECRET=

# ── ON-CHAIN ЛОГИРОВАНИЕ (только для китов) ─────────
ENABLE_ONCHAIN_LOG=true
# Приватный ключ кошелька, с которого платится газ (адрес 0x8B46... должен быть owner контракта)
WEB3_PRIVATE_KEY=0x...
# Адрес смарт-контракта VibeGuard на opBNB (не путать с кошельком!)
VIBEGUARD_CONTRACT=0x6e5e4E9E9C4F5E498393c4b6216781a28e15902F

# ── КАСТОМИЗАЦИЯ ─────────────────────────────────────
# Лимит китов задаётся в боте: /limit от 100 до любого значения (USD)
LOGO_URL=https://raw.githubusercontent.com/Tarran6/VibeGuard-AI/main/logo.png
